# Primary Gemini API Key (get yours at https://aistudio.google.com/apikey)
VITE_GEMINI_API_KEY=your_api_key_here

# Optional fallback keys (TEAM_006). If the primary key returns a 429,
# the app rotates to these in order. Generate each one from a SEPARATE
# Google account so they have independent free-tier quotas (1,000 RPD each).
# Leave blank if you only have one key — the rotation just becomes a
# single-key flow and the app works fine.
VITE_GEMINI_API_KEY_2=
VITE_GEMINI_API_KEY_3=
